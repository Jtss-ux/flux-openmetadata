# OpenMetadata MCP Server Configuration

# Host URL for OpenMetadata (default: http://localhost:8585 for local dev)
OPENMETADATA_HOST=http://localhost:8585

# API version (usually v1)
OPENMETADATA_API_VERSION=v1

# Authentication token from OpenMetadata/Collate console
# Get yours at: https://open-metadata.org/ or your Collate instance
OPENMETADATA_AUTH_TOKEN=your-token-here